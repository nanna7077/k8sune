{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "k8sune",
  "version": "0.1.0",
  "identifier": "com.nannan.k8sune",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix frontend",
    "beforeBuildCommand": "npm run build --prefix frontend"
  },
  "app": {
    "windows": [
      {
        "title": "k8sune",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/k8sune-icon.png",
      "icons/k8sune-icon.ico",
      "icons/k8sune-icon.icns"
    ],
    "resources": [
      "../backend/api/**/*",
      "../backend/cluster/**/*",
      "../backend/models/**/*",
      "../backend/utils/**/*",
      "../backend/libs/**/*",
      "../backend/main.py"
    ]
  }
}
